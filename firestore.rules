rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Pillar 0: Global Safety Net
    match /{document=**} { allow read, write: if false; }

    // Test Connection Path
    match /test/connection { allow read: if true; }
    
    // Pillar 3: Path Variable Hardening (isValidId)
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.\\@\\+\\:]+$'); 
    }
    
    // Pillar 2: Validation Blueprints (Helpers)
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    // --- COLLECTIONS ---

    match /employees/{id} { allow read, write: if true; }
    match /employeeChances/{id} { allow read, write: if true; }
    match /shifts/{id} { allow read, write: if true; }
    match /sections/{id} { allow read, write: if true; }
    match /divisions/{id} { allow read, write: if true; }
    match /jobPositions/{id} { allow read, write: if true; }
    match /jobLevels/{id} { allow read, write: if true; }
    match /attendance/{id} { allow read, write: if true; }
    match /manualAttendance/{id} { allow read, write: if true; }
    match /leaveRequests/{id} { allow read, write: if true; }
    match /periodQuotas/{id} { allow read, write: if true; }
    match /periodControls/{id} { allow read, write: if true; }
    match /activityLogs/{id} { allow read, write: if true; }
    match /config/{id} { allow read, write: if true; }
    match /systemConfig/{id} { allow read, write: if true; }
    match /potonganKehilanganConfig/{id} { allow read, write: if true; }
    match /potonganKehilanganBersamaConfig/{id} { allow read, write: if true; }
    match /bonusMasterConfig/{id} { allow read, write: if true; }
    match /bonusEstafet/{id} { allow read, write: if true; }
    match /bonusJagaDepan/{id} { allow read, write: if true; }
    match /bonusLainLain/{id} { allow read, write: if true; }
    match /bonusOperator/{id} { allow read, write: if true; }
    match /bonusNota/{id} { allow read, write: if true; }
    match /bonusBerat/{id} { allow read, write: if true; }
    match /koreksiGaji/{id} { allow read, write: if true; }
    match /koreksiGajiMinus/{id} { allow read, write: if true; }
    match /potonganSeragam/{id} { allow read, write: if true; }
    match /superAdmins/{id} { allow read, write: if true; }
    match /liburPeriods/{id} { allow read, write: if true; }
    match /quotas/{id} { allow read, write: if true; }
    
    match /potonganKehilangan/{employeeId}/debts/{debtId} {
        allow read, write: if true;
    }
    match /potonganKehilangan/{employeeId}/debts/{debtId}/payments/{paymentId} {
        allow read, write: if true;
    }
    match /potonganKehilanganBersama/{employeeId}/debtsBersama/{debtId} {
        allow read, write: if true;
    }
    match /potonganKehilanganBersama/{employeeId}/debtsBersama/{debtId}/paymentsBersama/{paymentId} {
        allow read, write: if true;
    }

    match /{path=**}/debts/{debt} {
        allow read, list: if true;
    }
    match /{path=**}/payments/{payment} {
        allow read, list: if true;
    }
    match /{path=**}/debtsBersama/{debt} {
        allow read, list: if true;
    }
    match /{path=**}/paymentsBersama/{payment} {
        allow read, list: if true;
    }
  }
}
