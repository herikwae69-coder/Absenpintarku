rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Pillar 3: Path Variable Hardening (isValidId)
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.]+$'); 
    }
    
    // Pillar 2: Validation Blueprints (Helpers)
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    // --- COLLECTIONS ---

    match /employees/{id} { allow read: if true; allow write: if isValidId(id); }
    match /shifts/{id} { allow read: if true; allow write: if isValidId(id); }
    match /sections/{id} { allow read: if true; allow write: if isValidId(id); }
    match /divisions/{id} { allow read: if true; allow write: if isValidId(id); }
    match /attendance/{id} { allow read: if true; allow write: if isValidId(id); }
    match /manualAttendance/{id} { allow read: if true; allow write: if isValidId(id); }
    match /leaveRequests/{id} { allow read: if true; allow write: if isValidId(id); }
    match /periodQuotas/{id} { allow read: if true; allow write: if isValidId(id); }
    match /periodControls/{id} { allow read: if true; allow write: if isValidId(id); }
    match /activityLogs/{id} { allow read: if true; allow write: if isValidId(id); }
    match /config/{id} { allow read: if true; allow write: if isValidId(id); }
    match /systemConfig/{id} { allow read: if true; allow write: if isValidId(id); }
    match /bonusMasterConfig/{id} { allow read: if true; allow write: if isValidId(id); }
    match /bonusEstafet/{id} { allow read: if true; allow write: if isValidId(id); }
    match /bonusJagaDepan/{id} { allow read: if true; allow write: if isValidId(id); }
    match /bonusLainLain/{id} { allow read: if true; allow write: if isValidId(id); }
    match /bonusOperator/{id} { allow read: if true; allow write: if isValidId(id); }
    match /bonusNota/{id} { allow read: if true; allow write: if isValidId(id); }
    match /bonusBerat/{id} { allow read: if true; allow write: if isValidId(id); }
    match /koreksiGaji/{id} { allow read: if true; allow write: if isValidId(id); }
    match /potonganKehilangan/{employeeId}/debts/{debtId} {
        allow read, get: if true;
        allow write: if isValidId(employeeId) && isValidId(debtId);
    }
    match /potonganKehilangan/{employeeId}/debts/{debtId}/payments/{paymentId} {
        allow read, get, list: if true;
        allow write: if isValidId(employeeId) && isValidId(debtId) && isValidId(paymentId);
    }

    match /{path=**}/debts/{debt} {
        allow read: if true;
    }
    match /{path=**}/payments/{payment} {
        allow read: if true;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
